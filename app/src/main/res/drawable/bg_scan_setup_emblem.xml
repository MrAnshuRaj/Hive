<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <gradient
                android:angle="270"
                android:endColor="#28150B03"
                android:startColor="#52311D07" />
            <stroke
                android:width="1dp"
                android:color="#45E6A81D" />
        </shape>
    </item>
    <item
        android:bottom="12dp"
        android:left="12dp"
        android:right="12dp"
        android:top="12dp">
        <shape android:shape="oval">
            <solid android:color="#14FFB117" />
        </shape>
    </item>
</layer-list>
