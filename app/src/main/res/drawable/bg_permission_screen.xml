<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@color/color_onboarding_bg" />
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:centerColor="#16100A"
                android:endColor="#090704"
                android:startColor="#1B140D" />
        </shape>
    </item>
    <item android:bottom="-120dp" android:left="-40dp" android:right="-40dp">
        <shape android:shape="oval">
            <gradient
                android:centerColor="#1FE1A526"
                android:endColor="@android:color/transparent"
                android:gradientRadius="240dp"
                android:startColor="#55FFBB1D"
                android:type="radial" />
        </shape>
    </item>
</layer-list>
