<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="45"
                android:endColor="#FFC013"
                android:startColor="#FFAE10" />
            <corners android:radius="@dimen/radius_28" />
        </shape>
    </item>
    <item android:top="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="#00FFFFFF"
                android:startColor="#26FFF5CA" />
            <corners android:radius="@dimen/radius_28" />
        </shape>
    </item>
</layer-list>
