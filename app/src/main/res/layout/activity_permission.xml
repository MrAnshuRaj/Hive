<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_onboarding_bg">

    <View
        android:id="@+id/viewPermissionBase"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_permission_screen"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/imagePermissionPattern"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:alpha="0.12"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_honeycomb_pattern_sparse"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/layoutPermissionContent"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="@dimen/space_24"
        android:paddingTop="@dimen/space_32"
        android:paddingEnd="@dimen/space_24"
        android:paddingBottom="@dimen/space_24"
        app:layout_constraintBottom_toTopOf="@id/layoutPermissionBottom"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.72">

        <FrameLayout
            android:layout_width="148dp"
            android:layout_height="148dp">

            <View
                android:layout_width="132dp"
                android:layout_height="132dp"
                android:layout_gravity="center"
                android:alpha="0.92"
                android:background="@drawable/bg_permission_icon_glow" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="136dp"
                android:layout_height="136dp"
                android:layout_gravity="center"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="@dimen/radius_28"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_permission_icon_tile">

                    <ImageView
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_folder"
                        app:tint="@color/white" />
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_24"
            android:fontFamily="sans-serif-black"
            android:text="@string/storage_access"
            android:textAlignment="center"
            android:textColor="@color/color_onboarding_text_primary"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textPermissionDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_16"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:text="@string/storage_access_message"
            android:textColor="@color/color_onboarding_text_secondary"
            android:textSize="18sp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_28"
            app:cardBackgroundColor="#241B13"
            app:cardCornerRadius="@dimen/radius_24"
            app:cardElevation="0dp"
            app:strokeColor="#4C3824"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="@dimen/space_20">

                <FrameLayout
                    android:layout_width="@dimen/feature_icon_size"
                    android:layout_height="@dimen/feature_icon_size"
                    android:background="@drawable/bg_permission_card_icon">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_photo"
                        app:tint="@color/color_onboarding_gold" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_16"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/photos_access"
                        android:textColor="@color/color_onboarding_text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_6"
                        android:text="@string/photos_access_subtitle"
                        android:textColor="#B7A99A"
                        android:textSize="15sp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_16"
            app:cardBackgroundColor="#241B13"
            app:cardCornerRadius="@dimen/radius_24"
            app:cardElevation="0dp"
            app:strokeColor="#4C3824"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="@dimen/space_20">

                <FrameLayout
                    android:layout_width="@dimen/feature_icon_size"
                    android:layout_height="@dimen/feature_icon_size"
                    android:background="@drawable/bg_permission_card_icon">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_video"
                        app:tint="@color/color_onboarding_gold" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_16"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/videos_access"
                        android:textColor="@color/color_onboarding_text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_6"
                        android:text="@string/videos_access_subtitle"
                        android:textColor="#B7A99A"
                        android:textSize="15sp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutPermissionBottom"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="@dimen/space_24"
        android:paddingEnd="@dimen/space_24"
        android:paddingBottom="@dimen/space_32"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_20"
            android:gravity="center"
            android:text="@string/privacy_note"
            android:textColor="#A69482"
            android:textSize="14sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonAllowAccess"
            style="@style/Widget.SafKaro.Button.OnboardingPrimary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:elevation="0dp"
            android:text="@string/allow_access"
            android:textAllCaps="false"
            android:textSize="18sp"
            app:backgroundTint="@color/color_onboarding_orange"
            app:cornerRadius="@dimen/radius_pill" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
