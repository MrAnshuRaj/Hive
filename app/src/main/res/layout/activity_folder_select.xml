<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_scan_setup_screen"
    android:orientation="vertical"
    android:paddingStart="@dimen/space_20"
    android:paddingTop="@dimen/space_16"
    android:paddingEnd="@dimen/space_20"
    android:paddingBottom="@dimen/space_20">

    <ImageView
        android:id="@+id/buttonBack"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/bg_scan_setup_back_chip"
        android:clickable="true"
        android:contentDescription="@string/back_to_home"
        android:focusable="true"
        android:padding="@dimen/space_10"
        android:src="@drawable/ic_back_arrow"
        app:tint="@color/color_scan_text_primary" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_20"
        android:text="@string/select_folders_title"
        android:textColor="@color/color_scan_text_primary"
        android:textSize="26sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_8"
        android:text="@string/select_folders_subtitle"
        android:textColor="@color/color_scan_text_secondary"
        android:textSize="16sp" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="@dimen/space_24">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerFolders"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="@dimen/space_16" />

        <LinearLayout
            android:id="@+id/layoutEmptyState"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/space_24"
            android:visibility="gone">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_folder"
                app:tint="@color/color_scan_gold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_16"
                android:text="@string/no_folders_found_title"
                android:textColor="@color/color_scan_text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_10"
                android:gravity="center"
                android:text="@string/no_folders_found"
                android:textColor="@color/color_scan_text_secondary"
                android:textSize="15sp" />
        </LinearLayout>
    </FrameLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonContinue"
        style="@style/Widget.SafKaro.Button.OnboardingPrimary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:enabled="false"
        android:text="@string/select_folder_to_scan_disabled" />
</LinearLayout>
