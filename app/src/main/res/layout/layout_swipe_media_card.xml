<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:cardBackgroundColor="#20150E"
    app:cardCornerRadius="@dimen/radius_28"
    app:cardElevation="0dp"
    app:strokeColor="#33FFFFFF"
    app:strokeWidth="1dp">

    <FrameLayout
        android:id="@+id/rootCard"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:id="@+id/imageCardPreview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop" />

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_onboarding_photo_scrim" />

        <LinearLayout
            android:id="@+id/layoutBestShotChip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|start"
            android:layout_marginStart="@dimen/space_16"
            android:layout_marginTop="@dimen/space_16"
            android:background="@drawable/bg_swipe_best_chip"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="@dimen/space_12"
            android:paddingTop="@dimen/space_8"
            android:paddingEnd="@dimen/space_12"
            android:paddingBottom="@dimen/space_8"
            android:visibility="gone">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_sparkle"
                android:tint="@color/white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_6"
                android:text="@string/best"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_marginTop="@dimen/space_16"
            android:layout_marginEnd="@dimen/space_16"
            android:background="@drawable/bg_swipe_chip_dark"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="@dimen/space_12"
            android:paddingTop="@dimen/space_8"
            android:paddingEnd="@dimen/space_12"
            android:paddingBottom="@dimen/space_8">

            <ImageView
                android:id="@+id/imageTypeIcon"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:tint="@color/white" />

            <TextView
                android:id="@+id/textTypeLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_6"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/buttonPlay"
            android:layout_width="74dp"
            android:layout_height="74dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_video_play_circle"
            android:padding="18dp"
            android:scaleType="centerInside"
            android:tint="@color/color_scan_gold"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/viewVideoProgressTrack"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_gravity="bottom"
            android:layout_marginStart="@dimen/space_24"
            android:layout_marginEnd="@dimen/space_24"
            android:layout_marginBottom="164dp"
            android:background="#55FFFFFF"
            android:gravity="start"
            android:orientation="horizontal"
            android:visibility="gone">

            <View
                android:id="@+id/viewVideoProgressFill"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/white"
                android:scaleX="0" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:layout_margin="@dimen/space_16"
            app:cardBackgroundColor="#B30B1508"
            app:cardCornerRadius="@dimen/radius_24"
            app:cardElevation="0dp"
            app:strokeColor="#26FFFFFF"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/space_18">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_folder"
                        android:tint="@color/color_scan_text_primary" />

                    <TextView
                        android:id="@+id/textBucketName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_8"
                        android:textColor="@color/color_scan_text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_8"
                        android:text="•"
                        android:textColor="@color/color_scan_text_secondary"
                        android:textSize="15sp" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginStart="@dimen/space_8"
                        android:src="@android:drawable/ic_menu_recent_history"
                        android:tint="@color/color_scan_text_primary" />

                    <TextView
                        android:id="@+id/textDateLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_8"
                        android:textColor="@color/color_scan_text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_18"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/swipe_file_size"
                            android:textAllCaps="true"
                            android:textColor="@color/color_scan_text_secondary"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/textSizeValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_6"
                            android:textColor="@color/color_scan_text_primary"
                            android:textSize="24sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <ImageButton
                        android:id="@+id/buttonInfo"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_swipe_info_button"
                        android:padding="10dp"
                        android:src="@android:drawable/ic_dialog_info"
                        android:tint="@color/color_scan_text_primary" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </FrameLayout>
</com.google.android.material.card.MaterialCardView>
