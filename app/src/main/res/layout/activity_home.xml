<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_onboarding_bg">

    <View
        android:id="@+id/viewHomeBase"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_home_screen"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/imageHomePattern"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:alpha="0.17"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_onboarding_pattern"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollHomeContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="120dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/space_24"
            android:paddingTop="@dimen/space_24"
            android:paddingEnd="@dimen/space_24"
            android:paddingBottom="@dimen/space_40">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/layoutBrand"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@drawable/ic_splash_hex" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_12"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.04"
                        android:text="@string/home_brand"
                        android:textColor="@color/color_onboarding_text_primary"
                        android:textSize="28sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/buttonAvatar"
                    android:layout_width="54dp"
                    android:layout_height="54dp"
                    android:background="@drawable/bg_home_avatar"
                    android:gravity="center"
                    android:text="@string/home_avatar_initials"
                    android:textColor="@color/color_onboarding_text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardStorageHero"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_20"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="@dimen/radius_28"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_home_hero_card"
                    android:padding="@dimen/space_16">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/home_storage_overview"
                            android:textColor="#E7DCCF"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/textHeroUsed"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_8"
                            android:textColor="@color/color_onboarding_text_primary"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <com.balraksh.hive.ui.home.StorageHoneycombView
                            android:id="@+id/viewStorageHoneycomb"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_8" />

                        <TextView
                            android:id="@+id/textHeroFootnote"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:textColor="#A8937F"
                            android:textSize="14sp" />
                    </LinearLayout>
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:id="@+id/layoutInsightSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_20"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_sparkle"
                        app:tint="@color/color_onboarding_orange" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_10"
                        android:text="@string/home_smart_insights"
                        android:textColor="@color/color_onboarding_text_primary"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <androidx.viewpager2.widget.ViewPager2
                    android:id="@+id/pagerSmartInsights"
                    android:layout_width="match_parent"
                    android:layout_height="188dp"
                    android:layout_marginTop="@dimen/space_16"
                    android:clipToPadding="false" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="@dimen/space_12"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <View
                        android:id="@+id/dotInsightOne"
                        android:layout_width="38dp"
                        android:layout_height="10dp"
                        android:background="@drawable/bg_home_indicator_active" />

                    <View
                        android:id="@+id/dotInsightTwo"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:layout_marginStart="@dimen/space_8"
                        android:background="@drawable/bg_home_indicator_inactive" />

                    <View
                        android:id="@+id/dotInsightThree"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:layout_marginStart="@dimen/space_8"
                        android:background="@drawable/bg_home_indicator_inactive" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutWeekSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_24"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_success"
                        app:tint="@color/color_onboarding_orange" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_10"
                        android:text="@string/home_this_week"
                        android:textColor="@color/color_onboarding_text_primary"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_16"
                    android:background="@drawable/bg_home_group_card"
                    android:orientation="horizontal"
                    android:padding="@dimen/space_16">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/space_10"
                        android:layout_weight="1"
                        android:background="@drawable/bg_home_stat_card"
                        android:gravity="center_horizontal"
                        android:orientation="vertical"
                        android:padding="@dimen/space_16">

                        <FrameLayout
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_permission_card_icon">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_success"
                                app:tint="#2FD69F" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/textStatSpaceFreedValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_16"
                            android:text="0 B"
                            android:textColor="@color/color_onboarding_text_primary"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_6"
                            android:gravity="center"
                            android:text="@string/home_stat_space_freed"
                            android:textColor="#B7A99A"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/space_10"
                        android:layout_weight="1"
                        android:background="@drawable/bg_home_stat_card"
                        android:gravity="center_horizontal"
                        android:orientation="vertical"
                        android:padding="@dimen/space_16">

                        <FrameLayout
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_permission_card_icon">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_folder_down"
                                app:tint="@color/color_onboarding_gold" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/textStatFilesValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_16"
                            android:text="0"
                            android:textColor="@color/color_onboarding_text_primary"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_6"
                            android:gravity="center"
                            android:text="@string/home_stat_files_organized"
                            android:textColor="#B7A99A"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_home_stat_card"
                        android:gravity="center_horizontal"
                        android:orientation="vertical"
                        android:padding="@dimen/space_16">

                        <FrameLayout
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_permission_card_icon">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_video"
                                app:tint="@color/color_onboarding_gold" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/textStatVideosValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_16"
                            android:text="0"
                            android:textColor="@color/color_onboarding_text_primary"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_6"
                            android:gravity="center"
                            android:text="@string/home_stat_videos_compressed"
                            android:textColor="#B7A99A"
                            android:textSize="14sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutQuickCleanupSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_24"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_sparkle"
                        app:tint="@color/color_onboarding_orange" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_10"
                        android:text="@string/home_quick_cleanup"
                        android:textColor="@color/color_onboarding_text_primary"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_16"
                    android:orientation="horizontal">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardQuickDuplicates"
                        android:layout_width="0dp"
                        android:layout_height="188dp"
                        android:layout_marginEnd="@dimen/space_10"
                        android:layout_weight="1"
                        app:cardBackgroundColor="@android:color/transparent"
                        app:cardCornerRadius="@dimen/radius_28"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_home_quick_card"
                            android:orientation="vertical"
                            android:padding="@dimen/space_16">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <FrameLayout
                                    android:layout_width="56dp"
                                    android:layout_height="56dp"
                                    android:background="@drawable/bg_permission_icon_tile">

                                    <ImageView
                                        android:layout_width="24dp"
                                        android:layout_height="24dp"
                                        android:layout_gravity="center"
                                        android:src="@drawable/ic_photo"
                                        app:tint="@color/white" />
                                </FrameLayout>

                                <TextView
                                    android:id="@+id/textQuickDuplicatesSpace"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="@dimen/space_12"
                                    android:background="@drawable/bg_home_badge"
                                    android:paddingHorizontal="@dimen/space_12"
                                    android:paddingVertical="@dimen/space_8"
                                    android:text="0 B"
                                    android:textColor="@color/color_onboarding_text_primary"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_28"
                                android:text="@string/quick_cleanup_duplicates"
                                android:textColor="@color/color_onboarding_text_primary"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/textQuickDuplicatesCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_8"
                                android:text="0 items"
                                android:textColor="#C1B29F"
                                android:textSize="16sp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardQuickSimilar"
                        android:layout_width="0dp"
                        android:layout_height="188dp"
                        android:layout_weight="1"
                        app:cardBackgroundColor="@android:color/transparent"
                        app:cardCornerRadius="@dimen/radius_28"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_home_quick_card"
                            android:orientation="vertical"
                            android:padding="@dimen/space_16">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <FrameLayout
                                    android:layout_width="56dp"
                                    android:layout_height="56dp"
                                    android:background="@drawable/bg_permission_icon_tile">

                                    <ImageView
                                        android:layout_width="24dp"
                                        android:layout_height="24dp"
                                        android:layout_gravity="center"
                                        android:src="@drawable/ic_screenshot"
                                        app:tint="@color/white" />
                                </FrameLayout>

                                <TextView
                                    android:id="@+id/textQuickSimilarSpace"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="@dimen/space_12"
                                    android:background="@drawable/bg_home_badge"
                                    android:paddingHorizontal="@dimen/space_12"
                                    android:paddingVertical="@dimen/space_8"
                                    android:text="0 B"
                                    android:textColor="@color/color_onboarding_text_primary"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_28"
                                android:text="@string/quick_cleanup_similar"
                                android:textColor="@color/color_onboarding_text_primary"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/textQuickSimilarCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_8"
                                android:text="0 items"
                                android:textColor="#C1B29F"
                                android:textSize="16sp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardQuickLargeVideos"
                    android:layout_width="match_parent"
                    android:layout_height="188dp"
                    android:layout_marginTop="@dimen/space_16"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardCornerRadius="@dimen/radius_28"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_home_quick_card"
                        android:orientation="vertical"
                        android:padding="@dimen/space_16">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <FrameLayout
                                android:layout_width="56dp"
                                android:layout_height="56dp"
                                android:background="@drawable/bg_permission_icon_tile">

                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_video"
                                    app:tint="@color/white" />
                            </FrameLayout>

                            <TextView
                                android:id="@+id/textQuickLargeVideosSpace"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/space_12"
                                android:background="@drawable/bg_home_badge"
                                android:paddingHorizontal="@dimen/space_12"
                                android:paddingVertical="@dimen/space_8"
                                android:text="0 B"
                                android:textColor="@color/color_onboarding_text_primary"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_28"
                            android:text="@string/quick_cleanup_large_videos"
                            android:textColor="@color/color_onboarding_text_primary"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/textQuickLargeVideosCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_8"
                            android:text="0 items"
                            android:textColor="#C1B29F"
                            android:textSize="16sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <FrameLayout
        android:id="@+id/layoutBottomNav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <include layout="@layout/include_bottom_nav" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
