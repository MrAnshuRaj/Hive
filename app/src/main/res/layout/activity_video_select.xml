<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_scan_setup_screen">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="@dimen/space_20"
            android:paddingTop="@dimen/space_24"
            android:paddingEnd="@dimen/space_20"
            android:paddingBottom="@dimen/space_12">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/video_compression_header_title"
                    android:textColor="@color/color_scan_text_primary"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_6"
                    android:text="@string/video_compression_header_subtitle"
                    android:textColor="@color/color_scan_text_secondary"
                    android:textSize="16sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/buttonAdvancedSettings"
                android:layout_width="56dp"
                android:layout_height="44dp"
                android:layout_marginEnd="@dimen/space_10"
                android:background="@drawable/bg_compress_button_circle"
                android:contentDescription="@string/advanced_options"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingStart="@dimen/space_10"
                android:paddingEnd="@dimen/space_8">

                <ImageView
                    android:id="@+id/imageAdvancedSettings"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_advanced_tune"
                    android:tint="@color/color_scan_text_primary" />

                <ImageView
                    android:id="@+id/imageAdvancedChevron"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginStart="@dimen/space_4"
                    android:src="@drawable/ic_chevron_down"
                    android:tint="@color/color_scan_text_primary" />
            </LinearLayout>

            <ImageView
                android:id="@+id/buttonFilter"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_compress_button_circle"
                android:contentDescription="@string/video_sort_options"
                android:padding="11dp"
                android:src="@drawable/ic_sort_order"
                android:tint="@color/color_scan_text_primary" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="@dimen/space_20"
            android:paddingTop="@dimen/space_12"
            android:paddingEnd="@dimen/space_20">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/video_quality_preference"
                android:textColor="@color/color_scan_text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textQualityHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/video_quality_hint_high"
                android:textColor="@color/color_scan_text_secondary"
                android:textSize="16sp" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.SafKaro.Card.CompressGlass"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_20"
            android:layout_marginTop="@dimen/space_12"
            android:layout_marginEnd="@dimen/space_20">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="@dimen/space_6">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonQualityHigh"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="@string/compression_strength_high"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    app:cornerRadius="@dimen/radius_24" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonQualityMedium"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_marginStart="@dimen/space_6"
                    android:layout_weight="1"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="@string/compression_strength_medium"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    app:cornerRadius="@dimen/radius_24" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonQualityLow"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_marginStart="@dimen/space_6"
                    android:layout_weight="1"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="@string/compression_strength_low"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    app:cornerRadius="@dimen/radius_24" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="@dimen/space_20"
            android:paddingTop="@dimen/space_24"
            android:paddingEnd="@dimen/space_20"
            android:paddingBottom="@dimen/space_12">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/video_select_section_title"
                android:textColor="@color/color_scan_text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textSelectAll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/select_all"
                android:textColor="@color/color_scan_gold"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerVideos"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingStart="@dimen/space_20"
                android:paddingEnd="@dimen/space_20"
                android:paddingBottom="280dp" />

            <LinearLayout
                android:id="@+id/layoutEmptyState"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="@dimen/space_24"
                android:visibility="gone">

                <ImageView
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:src="@drawable/ic_video"
                    android:tint="@color/color_scan_gold" />

                <TextView
                    android:id="@+id/textEmptyTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_16"
                    android:text="@string/no_videos_found"
                    android:textColor="@color/color_scan_text_primary"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/textEmptyMessage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_10"
                    android:gravity="center"
                    android:text="@string/no_videos_found_message"
                    android:textColor="@color/color_scan_text_secondary"
                    android:textSize="16sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonEmptyAction"
                    style="@style/Widget.SafKaro.Button.Outline"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_20"
                    android:text="@string/open_settings_for_video"
                    android:visibility="gone" />
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical">

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.SafKaro.Card.CompressSurface"
            android:id="@+id/cardSelectionSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_16"
            android:layout_marginEnd="@dimen/space_16"
            android:layout_marginBottom="@dimen/space_8"
            app:strokeColor="@color/color_scan_gold"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="@dimen/space_20">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/video_potential_savings"
                        android:textColor="@color/color_scan_text_secondary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/textPotentialSavingsValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_10"
                        android:text="0 MB"
                        android:textColor="@color/color_cleanup_success_green"
                        android:textSize="30sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/textSelectedSummary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_6"
                        android:text="0 videos selected"
                        android:textColor="@color/color_scan_text_secondary"
                        android:textSize="14sp" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonContinue"
                    style="@style/Widget.SafKaro.Button.CompressPrimary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:enabled="false"
                    android:text="@string/compress" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <include layout="@layout/include_bottom_nav" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/layoutAdvancedSettingsOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#8C000000" />

        <include
            android:id="@+id/cardAdvancedSettingsSheet"
            layout="@layout/layout_advanced_settings_dropdown"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom" />
    </FrameLayout>
</FrameLayout>
