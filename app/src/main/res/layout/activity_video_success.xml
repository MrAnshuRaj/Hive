<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_scan_setup_screen">

    <com.balraksh.hive.ui.cleanup.CleanupCelebrationView
        android:id="@+id/viewCelebration"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="@dimen/space_24"
            android:paddingTop="@dimen/space_40"
            android:paddingEnd="@dimen/space_24"
            android:paddingBottom="160dp">

            <FrameLayout
                android:id="@+id/layoutHeroIcon"
                android:layout_width="170dp"
                android:layout_height="170dp">

                <View
                    android:id="@+id/viewHeroGlow"
                    android:layout_width="160dp"
                    android:layout_height="160dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_video_success_glow" />

                <FrameLayout
                    android:id="@+id/viewHeroTile"
                    android:layout_width="126dp"
                    android:layout_height="126dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_video_success_icon_tile">

                    <ImageView
                        android:layout_width="62dp"
                        android:layout_height="62dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_folder_down"
                        app:tint="@color/white" />
                </FrameLayout>
            </FrameLayout>

            <TextView
                android:id="@+id/textSuccessTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_8"
                android:text="@string/video_success_title"
                android:textColor="@color/color_scan_text_primary"
                android:textSize="34sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textSuccessSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_8"
                android:gravity="center"
                android:text="@string/video_success_subtitle"
                android:textColor="@color/color_scan_text_secondary"
                android:textSize="17sp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_32"
                app:cardBackgroundColor="@color/color_video_success_surface"
                app:cardCornerRadius="@dimen/radius_28"
                app:cardElevation="0dp"
                app:strokeColor="@color/color_video_success_border"
                app:strokeWidth="1dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_cleanup_success_grid" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="@dimen/space_24"
                        android:paddingTop="@dimen/space_28"
                        android:paddingEnd="@dimen/space_24"
                        android:paddingBottom="@dimen/space_24">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_horizontal"
                            android:text="@string/cleanup_total_space_freed"
                            android:textAllCaps="true"
                            android:textColor="@color/color_scan_gold"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.16" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginTop="@dimen/space_18"
                            android:baselineAligned="false"
                            android:gravity="bottom"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/textFreedValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0.0"
                                android:textColor="@color/color_scan_gold"
                                android:textSize="64sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/textFreedUnit"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/space_8"
                                android:layout_marginBottom="12dp"
                                android:text="MB"
                                android:textColor="@color/color_scan_text_primary"
                                android:textSize="26sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/layoutStats"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_18"
                            android:gravity="center"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center_horizontal"
                                android:orientation="vertical">

                                <FrameLayout
                                    android:layout_width="56dp"
                                    android:layout_height="56dp"
                                    android:background="@drawable/bg_cleanup_success_stat_negative">

                                    <ImageView
                                        android:layout_width="24dp"
                                        android:layout_height="24dp"
                                        android:layout_gravity="center"
                                        android:src="@drawable/ic_delete"
                                        app:tint="#FF6767" />
                                </FrameLayout>

                                <TextView
                                    android:id="@+id/textFilesCount"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="@dimen/space_14"
                                    android:text="0"
                                    android:textColor="@color/color_scan_text_primary"
                                    android:textSize="18sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="@dimen/space_4"
                                    android:text="@string/cleanup_files_label"
                                    android:textAllCaps="true"
                                    android:textColor="@color/color_scan_text_secondary"
                                    android:textSize="12sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center_horizontal"
                                android:orientation="vertical">

                                <FrameLayout
                                    android:layout_width="56dp"
                                    android:layout_height="56dp"
                                    android:background="@drawable/bg_video_success_stat_neutral">

                                    <ImageView
                                        android:layout_width="24dp"
                                        android:layout_height="24dp"
                                        android:layout_gravity="center"
                                        android:src="@drawable/ic_video"
                                        app:tint="@color/color_scan_gold" />
                                </FrameLayout>

                                <TextView
                                    android:id="@+id/textMinutesCount"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="@dimen/space_14"
                                    android:text="0"
                                    android:textColor="@color/color_scan_text_primary"
                                    android:textSize="18sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="@dimen/space_4"
                                    android:text="@string/video_success_minutes"
                                    android:textAllCaps="true"
                                    android:textColor="@color/color_scan_text_secondary"
                                    android:textSize="12sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center_horizontal"
                                android:orientation="vertical">

                                <FrameLayout
                                    android:layout_width="56dp"
                                    android:layout_height="56dp"
                                    android:background="@drawable/bg_video_success_stat_positive">

                                    <ImageView
                                        android:layout_width="24dp"
                                        android:layout_height="24dp"
                                        android:layout_gravity="center"
                                        android:src="@drawable/ic_trending_up"
                                        app:tint="@color/color_cleanup_success_green" />
                                </FrameLayout>

                                <TextView
                                    android:id="@+id/textStoragePercent"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="@dimen/space_14"
                                    android:text="+0%"
                                    android:textColor="@color/color_cleanup_success_green"
                                    android:textSize="18sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="@dimen/space_4"
                                    android:text="@string/cleanup_storage_label"
                                    android:textAllCaps="true"
                                    android:textColor="@color/color_scan_text_secondary"
                                    android:textSize="12sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:id="@+id/layoutPrimaryAction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_28"
                android:orientation="vertical">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonBackHome"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:backgroundTint="@color/color_primary"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="@string/back_to_home"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:cornerRadius="@dimen/radius_24" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutSecondaryActions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonShareResults"
                    style="@style/Widget.SafKaro.Button.SuccessSecondary"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="@string/video_share_results"
                    app:icon="@drawable/ic_share"
                    app:iconGravity="textStart"
                    app:iconPadding="@dimen/space_8"
                    app:iconTint="@color/color_scan_text_primary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonShareApp"
                    style="@style/Widget.SafKaro.Button.SuccessSecondary"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_marginStart="@dimen/space_12"
                    android:layout_weight="1"
                    android:text="@string/video_share_app"
                    app:icon="@drawable/ic_phone_share"
                    app:iconGravity="textStart"
                    app:iconPadding="@dimen/space_8"
                    app:iconTint="@color/color_scan_text_primary" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonRateApp"
                style="@style/Widget.SafKaro.Button.SuccessSecondary"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="@dimen/space_12"
                android:text="@string/video_rate_app"
                app:icon="@drawable/ic_heart_outline"
                app:iconGravity="textStart"
                app:iconPadding="@dimen/space_8"
                app:iconTint="#FF7E8B" />
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical">

        <include layout="@layout/include_bottom_nav" />
    </LinearLayout>
</FrameLayout>
