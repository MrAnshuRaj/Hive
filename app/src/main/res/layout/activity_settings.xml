<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_home_screen"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/space_24"
        android:paddingTop="@dimen/space_24"
        android:paddingEnd="@dimen/space_24"
        android:paddingBottom="@dimen/space_32">

        <TextView
            android:id="@+id/buttonSettingsBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_home_badge"
            android:gravity="center"
            android:text="&lt;"
            android:textColor="@color/color_onboarding_text_primary"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_20"
            android:text="@string/home_account_settings"
            android:textColor="@color/color_onboarding_text_primary"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_12"
            android:text="@string/home_settings_subtitle"
            android:textColor="#B7A99A"
            android:textSize="16sp" />

        <LinearLayout
            android:id="@+id/rowSettingsNotifications"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_24"
            android:background="@drawable/bg_home_group_card"
            android:orientation="vertical"
            android:padding="@dimen/space_16">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_notifications"
                android:textColor="@color/color_onboarding_text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rowSettingsPrivacy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_12"
            android:background="@drawable/bg_home_group_card"
            android:orientation="vertical"
            android:padding="@dimen/space_16">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_privacy_security"
                android:textColor="@color/color_onboarding_text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rowSettingsHelp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_12"
            android:background="@drawable/bg_home_group_card"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/space_16">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/home_help_support"
                android:textColor="@color/color_onboarding_text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:contentDescription="@string/home_opens_in_web"
                android:src="@drawable/ic_open_in_web"
                android:tint="#C5B39F" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
