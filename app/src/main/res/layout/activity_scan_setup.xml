<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_scan_setup_screen">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="120dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/space_20"
            android:paddingTop="@dimen/space_16"
            android:paddingEnd="@dimen/space_20"
            android:paddingBottom="@dimen/space_28">

            <ImageView
                android:id="@+id/buttonBack"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_scan_setup_back_chip"
                android:clickable="true"
                android:contentDescription="@string/back_to_home"
                android:focusable="true"
                android:padding="@dimen/space_10"
                android:src="@drawable/ic_back_arrow"
                app:tint="@color/color_scan_text_primary" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_16"
                app:cardBackgroundColor="@color/color_scan_surface"
                app:cardCornerRadius="@dimen/radius_28"
                app:cardElevation="0dp"
                app:strokeColor="@color/color_scan_border"
                app:strokeWidth="1dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:alpha="0.34"
                        android:background="@drawable/bg_honeycomb_pattern_sparse" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="220dp"
                        android:background="@drawable/bg_scan_setup_glow" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="@dimen/space_28"
                        android:paddingTop="@dimen/space_28"
                        android:paddingEnd="@dimen/space_28"
                        android:paddingBottom="@dimen/space_28">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/clean_library_title"
                            android:textColor="@color/color_scan_text_primary"
                            android:textSize="28sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_8"
                            android:text="@string/clean_library_subtitle"
                            android:textColor="@color/color_scan_text_secondary"
                            android:textSize="16sp" />

                        <FrameLayout
                            android:layout_width="92dp"
                            android:layout_height="92dp"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginTop="@dimen/space_40"
                            android:background="@drawable/bg_scan_setup_emblem">

                            <ImageView
                                android:layout_width="34dp"
                                android:layout_height="34dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_sparkle"
                                app:tint="@color/color_scan_gold" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginTop="@dimen/space_28"
                            android:gravity="center"
                            android:text="@string/clean_library_panel_title"
                            android:textAlignment="center"
                            android:textColor="@color/color_scan_text_primary"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginTop="@dimen/space_10"
                            android:gravity="center"
                            android:text="@string/clean_library_panel_subtitle"
                            android:textAlignment="center"
                            android:textColor="@color/color_scan_text_secondary"
                            android:textSize="16sp" />

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardAllImages"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_32"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            app:cardBackgroundColor="@color/color_scan_surface_active"
                            app:cardCornerRadius="@dimen/radius_24"
                            app:cardElevation="0dp"
                            app:strokeColor="@color/color_scan_gold"
                            app:strokeWidth="1dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:minHeight="92dp"
                                android:orientation="horizontal"
                                android:paddingStart="@dimen/space_20"
                                android:paddingTop="@dimen/space_16"
                                android:paddingEnd="@dimen/space_20"
                                android:paddingBottom="@dimen/space_16">

                                <FrameLayout
                                    android:layout_width="60dp"
                                    android:layout_height="60dp"
                                    android:background="@drawable/bg_scan_setup_icon_tile">

                                    <ImageView
                                        android:layout_width="24dp"
                                        android:layout_height="24dp"
                                        android:layout_gravity="center"
                                        android:src="@drawable/ic_photo"
                                        app:tint="@color/color_scan_gold" />
                                </FrameLayout>

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="@dimen/space_16"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:id="@+id/textAllImagesTitle"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="@string/scan_all_images_cta"
                                        android:textColor="@color/color_scan_gold"
                                        android:textSize="17sp"
                                        android:textStyle="bold" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="@dimen/space_6"
                                        android:text="@string/scan_all_images_cta_subtitle"
                                        android:textColor="@color/color_scan_text_secondary"
                                        android:textSize="14sp" />
                                </LinearLayout>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardSelectFolder"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_16"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            app:cardBackgroundColor="@color/color_scan_surface_alt"
                            app:cardCornerRadius="@dimen/radius_24"
                            app:cardElevation="0dp"
                            app:strokeColor="@color/color_scan_border"
                            app:strokeWidth="1dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:minHeight="92dp"
                                android:orientation="horizontal"
                                android:paddingStart="@dimen/space_20"
                                android:paddingTop="@dimen/space_16"
                                android:paddingEnd="@dimen/space_20"
                                android:paddingBottom="@dimen/space_16">

                                <FrameLayout
                                    android:layout_width="60dp"
                                    android:layout_height="60dp"
                                    android:background="@drawable/bg_scan_setup_icon_tile">

                                    <ImageView
                                        android:layout_width="24dp"
                                        android:layout_height="24dp"
                                        android:layout_gravity="center"
                                        android:src="@drawable/ic_folder"
                                        app:tint="@color/color_scan_gold" />
                                </FrameLayout>

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="@dimen/space_16"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:id="@+id/textFolderTitle"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="@string/scan_specific_folder"
                                        android:textColor="@color/color_scan_text_primary"
                                        android:textSize="17sp"
                                        android:textStyle="bold" />

                                    <TextView
                                        android:id="@+id/textSelectFolderSubtitle"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="@dimen/space_6"
                                        android:text="@string/scan_specific_folder_subtitle"
                                        android:textColor="@color/color_scan_text_secondary"
                                        android:textSize="14sp" />
                                </LinearLayout>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_20"
                            app:cardBackgroundColor="@color/color_scan_note_surface"
                            app:cardCornerRadius="@dimen/radius_20"
                            app:cardElevation="0dp"
                            app:strokeColor="@color/color_scan_note_border"
                            app:strokeWidth="1dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal"
                                android:paddingStart="@dimen/space_20"
                                android:paddingTop="@dimen/space_16"
                                android:paddingEnd="@dimen/space_20"
                                android:paddingBottom="@dimen/space_16">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:src="@drawable/ic_shield"
                                    app:tint="@color/color_scan_text_secondary" />

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="@dimen/space_14"
                                    android:layout_weight="1"
                                    android:text="@string/scan_privacy_note_local"
                                    android:textColor="@color/color_scan_text_secondary"
                                    android:textSize="14sp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </ScrollView>

    <FrameLayout
        android:id="@+id/layoutBottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom">

        <include layout="@layout/include_bottom_nav" />
    </FrameLayout>
</FrameLayout>
